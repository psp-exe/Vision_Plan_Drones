      <static>1</static>
      <pose>14 0 2.5 0 0 1.5708</pose>
      <link name='link'>
        <collision name='collision'>
          <geometry>
            <box><size>28 0.2 5</size></box>
          </geometry>
        </collision>
        <visual name='visual'>
          <geometry>
            <box><size>28 0.2 5</size></box>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.75 1</ambient>
            <diffuse>0.9 0.9 0.85 1</diffuse>
          </material>
        </visual>
      </link>
    </model>
    
    <!-- West Wall -->
    <model name='wall_west'>
      <static>1</static>
      <pose>-14 0 2.5 0 0 1.5708</pose>
      <link name='link'>
        <collision name='collision'>
          <geometry>
            <box><size>28 0.2 5</size></box>
          </geometry>
        </collision>
        <visual name='visual'>
          <geometry>
