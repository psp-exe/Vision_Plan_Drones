          <material>
            <ambient>0.4 0.35 0.3 1</ambient>
            <diffuse>0.5 0.45 0.4 1</diffuse>
          </material>
        </visual>
        <collision name='shelf_collision'>
          <pose>0 0 1.5 0 0 0</pose>
          <geometry><box><size>0.8 5 3</size></box></geometry>
        </collision>
      </link>
    </model>
    
