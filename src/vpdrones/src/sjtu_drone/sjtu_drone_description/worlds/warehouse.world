    <!-- =========================================================== -->
    <!-- CHARGING STATION (Drone Home Base) -->
    <!-- =========================================================== -->
    
    <model name='charging_station'>
      <static>1</static>
      <pose>0 0 0.05 0 0 0</pose>
      <link name='link'>
        <collision name='collision'>
          <geometry>
            <cylinder>
              <radius>1.0</radius>
              <length>0.1</length>
            </cylinder>
