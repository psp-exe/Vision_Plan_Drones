<?xml version="1.0" ?>
<!-- 
  Warehouse Environment for Drone Navigation and VLM Training
  Contains: Warehouse floor, walls, shelving units, colored boxes
  
  Color scheme for object detection training:
  - Red boxes: Fragile items
  - Blue boxes: Standard items
  - Green boxes: Large items
  - Yellow boxes: Hazardous materials
  - Orange boxes: Express shipping
  - White boxes: Returns
-->
<sdf version='1.7'>
  <world name='warehouse'>
    
    <!-- =========================================================== -->
    <!-- LIGHTING -->
    <!-- =========================================================== -->
    <light name='warehouse_light_1' type='directional'>
      <cast_shadows>1</cast_shadows>
      <pose>0 0 15 0 -0 0</pose>
      <diffuse>0.9 0.9 0.9 1</diffuse>
      <specular>0.3 0.3 0.3 1</specular>
      <attenuation>
        <range>100</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>0.1 0.1 -0.9</direction>
    </light>
    
    <light name='warehouse_light_2' type='point'>
      <pose>5 5 8 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>30</range>
        <constant>0.5</constant>
        <linear>0.01</linear>
        <quadratic>0.01</quadratic>
      </attenuation>
    </light>
    
    <light name='warehouse_light_3' type='point'>
      <pose>-5 -5 8 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>30</range>
        <constant>0.5</constant>
        <linear>0.01</linear>
        <quadratic>0.01</quadratic>
      </attenuation>
    </light>
    
    <!-- =========================================================== -->
    <!-- PHYSICS & ENVIRONMENT -->
    <!-- =========================================================== -->
    <gravity>0 0 -9.8</gravity>
    <magnetic_field>6e-06 2.3e-05 -4.2e-05</magnetic_field>
    <atmosphere type='adiabatic'/>
    
    <physics type='ode'>
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>
    
    <scene>
      <ambient>0.5 0.5 0.5 1</ambient>
      <background>0.3 0.3 0.4 1</background>
      <shadows>1</shadows>
    </scene>
    
    <!-- =========================================================== -->
    <!-- GROUND PLANE (Warehouse Floor) -->
    <!-- =========================================================== -->
    <model name='warehouse_floor'>
      <static>1</static>
      <pose>0 0 0 0 0 0</pose>
      <link name='floor_link'>
        <collision name='floor_collision'>
          <geometry>
            <box>
              <size>30 30 0.1</size>
            </box>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>100</mu>
                <mu2>50</mu2>
              </ode>
            </friction>
          </surface>
        </collision>
        <visual name='floor_visual'>
          <geometry>
            <box>
              <size>30 30 0.1</size>
            </box>
          </geometry>
          <material>
            <ambient>0.6 0.6 0.6 1</ambient>
            <diffuse>0.7 0.7 0.7 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>
    
    <!-- =========================================================== -->
    <!-- WAREHOUSE WALLS -->
    <!-- =========================================================== -->
    
    <!-- North Wall -->
    <model name='wall_north'>
      <static>1</static>
      <pose>0 14 2.5 0 0 0</pose>
      <link name='link'>
        <collision name='collision'>
          <geometry>
            <box><size>30 0.2 5</size></box>
          </geometry>
        </collision>
        <visual name='visual'>
          <geometry>
            <box><size>30 0.2 5</size></box>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.75 1</ambient>
            <diffuse>0.9 0.9 0.85 1</diffuse>
          </material>
        </visual>
      </link>
    </model>
    
    <!-- South Wall -->
    <model name='wall_south'>
      <static>1</static>
      <pose>0 -14 2.5 0 0 0</pose>
      <link name='link'>
        <collision name='collision'>
          <geometry>
            <box><size>30 0.2 5</size></box>
          </geometry>
        </collision>
        <visual name='visual'>
          <geometry>
            <box><size>30 0.2 5</size></box>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.75 1</ambient>
            <diffuse>0.9 0.9 0.85 1</diffuse>
          </material>
        </visual>
      </link>
    </model>
    
    <!-- East Wall -->
