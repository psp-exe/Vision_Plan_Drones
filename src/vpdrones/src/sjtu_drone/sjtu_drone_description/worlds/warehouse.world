    <!-- SHELVING UNITS (Warehouse Racks) -->
    <!-- =========================================================== -->
    
    <!-- Shelf Unit 1 (Left side) -->
    <model name='shelf_unit_1'>
      <static>1</static>
      <pose>-8 0 0 0 0 0</pose>
      <link name='shelf_frame'>
        <!-- Vertical posts -->
        <visual name='post_1'>
          <pose>0 -2 1.5 0 0 0</pose>
          <geometry><box><size>0.1 0.1 3</size></box></geometry>
          <material>
            <ambient>0.3 0.3 0.35 1</ambient>
            <diffuse>0.4 0.4 0.45 1</diffuse>
          </material>
        </visual>
        <visual name='post_2'>
